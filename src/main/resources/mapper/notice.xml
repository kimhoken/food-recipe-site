<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.foodsite.dao.NoticeDAO">

    <!-- 공지사항 목록 -->
    <select id="selectList" resultType="notice">
        select *
        from notice
        order by notice_id desc
        limit #{start}, #{pageSize}
    </select>

    <!-- 공지사항 개수 -->
    <select id="notice_count" resultType="int">
        select count(*)
        from notice
    </select>

    <!-- 공지사항 상세 -->
    <select id="noticeView" parameterType="int" resultType="notice">
        select *
        from notice
        where notice_id = #{notice_id}
    </select>

    <!-- 조회 기록 추가 -->
    <insert id="viewHistory" parameterType="java.util.Map">
        insert ignore into notice_view (
            notice_id,
            member_id
        ) values (
            #{notice_id},
            #{member_id}
        )
    </insert>

    <!-- 조회수 증가 -->
    <update id="userViewCount" parameterType="int">
        update notice
        set view_count = view_count + 1
        where notice_id = #{notice_id}
    </update>

    <!-- 이미지 등록 -->
    <insert id="img_insert" parameterType="img">
        insert into img (
            image_list
        ) values (
            #{image_list}
        )
    </insert>

    <!-- 마지막 이미지 번호 조회 -->
    <select id="img_max_id" resultType="int">
        select max(img_id)
        from img
    </select>

    <!-- 이미지 조회 -->
    <select id="img_select" parameterType="int" resultType="img">
        select *
        from img
        where img_id = #{img_id}
    </select>

    <!-- 공지사항 등록 -->
    <insert id="notice_insert" parameterType="notice">
        insert into notice (
            member_id,
            img_id,
            title,
            content,
            created_date,
            view_count
        ) values (
            #{member_id},
            #{img_id},
            #{title},
            #{content},
            now(),
            0
        )
    </insert>

    <!-- 공지사항 수정 -->
    <update id="notice_update" parameterType="notice">
        update notice
        set title = #{title},
            content = #{content},
            img_id = #{img_id}
        where notice_id = #{notice_id}
    </update>

    <!-- 공지사항 삭제 -->
    <delete id="notice_delete" parameterType="int">
        delete from notice
        where notice_id = #{notice_id}
    </delete>

</mapper>