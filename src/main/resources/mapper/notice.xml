<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.foodsite.dao.NoticeDAO">

    <!-- 공지사항 목록 -->
    <select id="selectAll" resultType="notice">
        select * from notice
        order by notice_id desc
    </select>

    <!-- 공지사항 상세정보 -->
    <select id="noticeView"
            parameterType="int"
            resultType="notice">
        select * from notice 
        where notice_id = #{notice_id}
    </select>

    <!-- 공지사항 등록 -->
    <insert id="notice_insert"
            parameterType="notice">
        insert into notice (
            member_id, title, content,created_date, view_count
        )values (
            #{member_id},#{title},#{content},NOW(), 0 )

    </insert>
    <!-- 공지사항 삭제 -->
    <delete id="notice_delete" parameterType="int">
        delete from notice
        where notice_id = #{notice_id}
    </delete>

    <update id="notice_update" parameterType="notice">
        UPDATE notice
        SET title = #{title},
            content = #{content}
        WHERE notice_id = #{notice_id}
        AND member_id = #{member_id}
    </update>
</mapper>