<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.foodsite.dao.NoticeDAO">

    <select id="selectList" resultType="notice">
        select *
        from notice
        <where>
            <if test="search_text != null and search_text != ''">
                title like concat('%', #{search_text}, '%')
            </if>
        </where>
        order by notice_id desc
        limit #{start}, #{pageSize}
    </select>

    <select id="notice_count" resultType="int">
        select count(*)
        from notice
        <where>
            <if test="search_text != null and search_text != ''">
                title like concat('%', #{search_text}, '%')
            </if>
        </where>
    </select>

    <select id="noticeView" parameterType="int" resultType="notice">
        select *
        from notice
        where notice_id = #{notice_id}
    </select>

    <insert id="notice_insert" parameterType="notice"
            useGeneratedKeys="true" keyProperty="notice_id">
        insert into notice (
            member_id,
            title,
            content,
            view_count,
            created_date
        ) values (
            #{member_id},
            #{title},
            #{content},
            0,
            now()
        )
    </insert>

    <insert id="notice_img_insert" parameterType="img"
            useGeneratedKeys="true" keyProperty="img_id">
        insert into img (
            image_list,
            notice_id
        ) values (
            #{image_list},
            #{notice_id}
        )
    </insert>

    <select id="notice_img_select" parameterType="int" resultType="img">
        select *
        from img
        where notice_id = #{notice_id}
        limit 1
    </select>

    <update id="notice_img_update" parameterType="img">
        update img
        set image_list = #{image_list}
        where notice_id = #{notice_id}
    </update>

    <delete id="notice_img_delete" parameterType="int">
        delete from img
        where notice_id = #{notice_id}
    </delete>

    <update id="notice_update" parameterType="notice">
        update notice
        set
            title = #{title},
            content = #{content}
        where notice_id = #{notice_id}
    </update>

    <delete id="notice_delete" parameterType="int">
        delete from notice
        where notice_id = #{notice_id}
    </delete>

</mapper>