<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.project.foodsite.dao.TokenDAO">
    
    <insert id="insertToken" parameterType="token">
        INSERT INTO password_reset_token (member_id, token, created_date, expire_date) VALUES (#{member_id}, #{token}, now(), #{expire_date} )
    </insert>
	
    <select id="getToken" parameterType="String" resultType="token">
        SELECT * FROM password_reset_token WHERE token = #{token}
    </select>    
    

</mapper>