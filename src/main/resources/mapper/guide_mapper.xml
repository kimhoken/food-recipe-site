<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.foodsite.dao.GuideDAO">

/* 목록 조회 */
    <select id="guideTab" parameterType="string" resultType="com.project.foodsite.dto.GuideDTO">
        SELECT 
            guide_id, 
            title, 
            sub_title, 
            image, 
            tab, 
            content, 
            created_at 
        FROM guide_table
        <where>
            <if test="tab != null and tab != '' and tab != 'all'">
                tab = #{tab}
            </if>
        </where>
        ORDER BY guide_id DESC
    </select>

</mapper>