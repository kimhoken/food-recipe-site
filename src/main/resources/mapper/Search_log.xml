<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace는 기본패키지 + dao로 설정해야함
    ex) com.kh.dept.dao.DeptDAO
-->
<mapper namespace="com.project.foodsite.dao.SearchLogDAO">
	<insert id="insertKeyWord" parameterType="String">
        INSERT INTO search_log(keyword, created_at) VALUES(#{search}, now()) 
    </insert>

    <select id="selectTrendingKeywords" resultType="String">
        SELECT keyword
        FROM search_log
        WHERE created_at >= DATE_SUB(NOW(), INTERVAL 1 HOUR)
        GROUP BY keyword
        ORDER BY COUNT(keyword) DESC
        LIMIT 10
    </select>

    <delete id="deleteLog">
        delete from search_log
    </delete>

    <select id="initCache" resultType="String">
        SELECT keyword, COUNT(keyword) FROM search_log
        GROUP BY keyword
        ORDER BY COUNT(keyword) DESC
        LIMIT 10
    </select>

    <!-- 임의로 고침(안두면 메인 오류) -->
    <!-- 
        SELECT keyword FROM v_keyword_ranking
        ORDER BY ranking DESC
    -->
    <select id="getRecommand" resultType="String">
        SELECT '' AS keyword
    </select>

</mapper>